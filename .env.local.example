; Copy this file to .env.local and fill in real values.
; Generate an API key at https://nicnames.com/en/my/settings (paid membership required).

NICNAMES_API_KEY=

; Optional override of the API base URL (defaults to https://api.nicnames.com/2).
;NICNAMES_BASE_URL=https://api.nicnames.com/2

; Optional contact id used by examples/register.php and examples/transfer.php
; when --registrant is not passed on the command line.
;NICNAMES_DEFAULT_REGISTRANT=c987654321
