{
    "name": "luchaninov/nicnames-client",
    "description": "PHP client for the Nicnames domain registrar REST API v2",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "nicnames",
        "domain-registrar",
        "domains",
        "api-client",
        "rest-client"
    ],
    "support": {
        "issues": "https://github.com/luchaninov/nicnames-client/issues",
        "source": "https://github.com/luchaninov/nicnames-client"
    },
    "require": {
        "php": ">=8.4",
        "psr/log": "^3.0",
        "symfony/http-client": "^7.4 || ^8.0"
    },
    "require-dev": {
        "phpstan/phpstan": "^2.1",
        "monolog/monolog": "^3.0",
        "phpunit/phpunit": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Luchaninov\\NicnamesClient\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Luchaninov\\NicnamesClient\\Tests\\": "tests/"
        }
    }
}
